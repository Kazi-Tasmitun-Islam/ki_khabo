# Uncomment this line to define a global platform for your project
# platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO' if config.build_settings['SDKROOT'] == 'iphonesimulator' || config.name == 'Debug'
    end
  end

  # Fix for "detritus not allowed" and "Failed to codesign" errors
  project_path = 'Runner.xcodeproj'
  project = Xcodeproj::Project.open(project_path)
  runner_target = project.targets.find { |t| t.name == 'Runner' }
  if runner_target
    runner_target.build_configurations.each do |config|
      if config.build_settings['SDKROOT'] == 'iphonesimulator' || config.name == 'Debug'
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      end
    end

    phase_name = 'Strip Detritus'
    existing_phase = runner_target.shell_script_build_phases.find { |p| p.name == phase_name }
    if existing_phase
      # Move existing phase to the front and update script
      runner_target.build_phases.insert(0, runner_target.build_phases.delete(existing_phase))
      existing_phase.shell_script = 'find "${SRCROOT}/.." -type d -name "*.framework" -print0 | xargs -0 xattr -cr 2>/dev/null; find "${BUILT_PRODUCTS_DIR}" -type f -print0 | xargs -0 xattr -cr 2>/dev/null; true'
    else
      phase = runner_target.new_shell_script_build_phase(phase_name)
      phase.shell_script = 'find "${SRCROOT}/.." -type d -name "*.framework" -print0 | xargs -0 xattr -cr 2>/dev/null; find "${BUILT_PRODUCTS_DIR}" -type f -print0 | xargs -0 xattr -cr 2>/dev/null; true'
      phase.show_env_vars_in_log = '0'
      runner_target.build_phases.insert(0, runner_target.build_phases.delete(phase))
    end
    project.save
  end
end
